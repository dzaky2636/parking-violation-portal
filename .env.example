# Supabase credentials (from your Supabase project dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database URL — MUST use Supabase session pooler (port 6543)
# Direct connection (db.xxx.supabase.co:5432) is IPv6-only and unreachable
SUPABASE_DATABASE_URL=postgresql://postgres.xxx:[password]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
